1. SELECT (Read Data)

Retrieve data from a table.

SELECT * FROM customers;

Explanation: Returns all columns and rows from customers.

Select specific columns:

SELECT first_name, last_name
FROM customers;
2. WHERE (Filter Data)
SELECT *
FROM customers
WHERE city = 'Amsterdam';

Explanation: Returns only customers from Amsterdam.

Comparison Operators
Operator	Meaning
=	Equal
!= or <>	Not equal
>	Greater than
<	Less than
>=	Greater or equal
<=	Less or equal

Example:

SELECT *
FROM products
WHERE price > 100;
3. AND / OR / NOT
SELECT *
FROM employees
WHERE department = 'IT'
AND salary > 50000;
SELECT *
FROM employees
WHERE department = 'IT'
OR department = 'HR';
SELECT *
FROM employees
WHERE NOT department = 'Sales';
4. ORDER BY (Sort Results)

Ascending:

SELECT *
FROM products
ORDER BY price ASC;

Descending:

SELECT *
FROM products
ORDER BY price DESC;
5. LIMIT / TOP

MySQL/PostgreSQL:

SELECT *
FROM customers
LIMIT 5;

SQL Server:

SELECT TOP 5 *
FROM customers;

Explanation: Returns the first 5 rows.

6. DISTINCT

Remove duplicates.

SELECT DISTINCT city
FROM customers;
7. LIKE (Pattern Matching)

Starts with A:

SELECT *
FROM customers
WHERE name LIKE 'A%';

Ends with n:

SELECT *
FROM customers
WHERE name LIKE '%n';

Contains "an":

SELECT *
FROM customers
WHERE name LIKE '%an%';
8. IN
SELECT *
FROM customers
WHERE city IN ('Amsterdam', 'Rotterdam');
9. BETWEEN
SELECT *
FROM products
WHERE price BETWEEN 50 AND 100;
10. IS NULL
SELECT *
FROM customers
WHERE phone IS NULL;

Not null:

SELECT *
FROM customers
WHERE phone IS NOT NULL;
Aggregate Functions
COUNT
SELECT COUNT(*)
FROM customers;

Counts rows.

SUM
SELECT SUM(price)
FROM orders;

Adds values.

AVG
SELECT AVG(price)
FROM products;

Average value.

MIN / MAX
SELECT MIN(price), MAX(price)
FROM products;
GROUP BY

Group records together.

SELECT department,
       COUNT(*) AS employees
FROM employees
GROUP BY department;

Example output:

department	employees
IT	10
HR	4
HAVING

Filter grouped results.

SELECT department,
       COUNT(*)
FROM employees
GROUP BY department
HAVING COUNT(*) > 5;
INSERT

Add data.

INSERT INTO customers
(first_name, last_name, city)
VALUES
('John', 'Doe', 'Amsterdam');
UPDATE

Modify data.

UPDATE customers
SET city = 'Rotterdam'
WHERE customer_id = 1;

⚠ Always use WHERE unless you want to update every row.

DELETE

Delete data.

DELETE FROM customers
WHERE customer_id = 1;

⚠ Without WHERE, all rows are deleted.

CREATE TABLE
CREATE TABLE customers (
    customer_id INT PRIMARY KEY,
    first_name VARCHAR(50),
    last_name VARCHAR(50),
    city VARCHAR(50)
);
ALTER TABLE

Add a column:

ALTER TABLE customers
ADD email VARCHAR(100);

Remove a column:

ALTER TABLE customers
DROP COLUMN email;
DROP TABLE
DROP TABLE customers;

Deletes the table permanently.

PRIMARY KEY
CREATE TABLE customers (
    customer_id INT PRIMARY KEY,
    name VARCHAR(50)
);

Unique identifier.

FOREIGN KEY
CREATE TABLE orders (
    order_id INT PRIMARY KEY,
    customer_id INT,
    FOREIGN KEY (customer_id)
    REFERENCES customers(customer_id)
);

Links tables together.

JOINS

Assume:

Customers
customer_id	name
1	John
2	Sarah
Orders
order_id	customer_id
101	1
102	1
INNER JOIN
SELECT c.name, o.order_id
FROM customers c
INNER JOIN orders o
ON c.customer_id = o.customer_id;

Returns matching rows only.

LEFT JOIN
SELECT c.name, o.order_id
FROM customers c
LEFT JOIN orders o
ON c.customer_id = o.customer_id;

Returns all customers, even without orders.

RIGHT JOIN
SELECT c.name, o.order_id
FROM customers c
RIGHT JOIN orders o
ON c.customer_id = o.customer_id;

Returns all orders.

FULL OUTER JOIN
SELECT c.name, o.order_id
FROM customers c
FULL OUTER JOIN orders o
ON c.customer_id = o.customer_id;

Returns everything from both tables.

Subqueries
SELECT *
FROM employees
WHERE salary >
(
    SELECT AVG(salary)
    FROM employees
);

Employees earning above average.

UNION

Combine results.

SELECT city
FROM customers

UNION

SELECT city
FROM suppliers;

Removes duplicates.

Keep duplicates:

UNION ALL
CASE

Like IF/ELSE.

SELECT name,
CASE
    WHEN salary > 70000 THEN 'High'
    WHEN salary > 40000 THEN 'Medium'
    ELSE 'Low'
END AS salary_group
FROM employees;
Views

Create virtual tables.

CREATE VIEW active_customers AS
SELECT *
FROM customers
WHERE active = 1;

Use:

SELECT *
FROM active_customers;
Indexes

Improve search speed.

CREATE INDEX idx_name
ON customers(last_name);
Transactions
BEGIN TRANSACTION;

UPDATE accounts
SET balance = balance - 100
WHERE id = 1;

UPDATE accounts
SET balance = balance + 100
WHERE id = 2;

COMMIT;

Undo changes:

ROLLBACK;
Most Common SQL Interview Queries
Second Highest Salary
SELECT MAX(salary)
FROM employees
WHERE salary <
(
    SELECT MAX(salary)
    FROM employees
);
Duplicate Records
SELECT email, COUNT(*)
FROM users
GROUP BY email
HAVING COUNT(*) > 1;
Top 3 Highest Salaries
SELECT *
FROM employees
ORDER BY salary DESC
LIMIT 3;
Total Sales Per Customer
SELECT customer_id,
       SUM(amount) AS total_sales
FROM orders
GROUP BY customer_id;
